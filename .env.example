# Diese Datei nach ".env" kopieren (docker compose liest sie automatisch).
#   cp .env.example .env  &&  nano .env

# Zugangspasswort für normale Nutzer (Rolle "user"). Frei wählen, gern lang.
AUTH_PASSWORD=BitteHierEinStarkesPasswort

# Admin-Passwort (Rolle "admin", darf auf der Admin-Seite alles verwalten).
# Optional - leer lassen, wenn du keinen Admin-Zugang brauchst.
ADMIN_PASSWORD=EinAnderesStarkesAdminPasswort

# Schlüssel zum Signieren der Login-Cookies. Einmalig erzeugen mit:
#   openssl rand -hex 32
SESSION_SECRET=hier-einen-zufaelligen-32-byte-hex-wert-eintragen
